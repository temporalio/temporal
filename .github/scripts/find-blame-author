#!/usr/bin/env python3
# Usage: find-blame-author
# Reads the diff of HEAD^..HEAD (HEAD^ is the pre-fix state; requires full
# history), runs git blame on the original line ranges touched by each hunk,
# and prints the email address of the author with the most blame hits.
# Prints nothing if no author can be determined.

import re
import subprocess
import sys
from collections import Counter

diff = subprocess.check_output(
    ['git', 'diff', 'HEAD^..HEAD', '--unified=0'], text=True)

current_file = None
ranges = []
for line in diff.splitlines():
    if line.startswith('--- '):
        # '--- a/<path>' is a modified/deleted file; anything else (e.g. /dev/null)
        # is a new file with no pre-image to blame.
        current_file = line[6:] if line.startswith('--- a/') else None
    elif line.startswith('@@ '):
        m = re.match(r'^@@ -(\d+)(?:,(\d+))? ', line)
        if m and current_file:
            start = int(m.group(1))
            count = int(m.group(2) if m.group(2) is not None else '1')
            if count > 0:
                ranges.append((current_file, start, count))

email_counts = Counter()
for file, start, count in ranges:
    result = subprocess.run(
        ['git', 'blame', 'HEAD^', f'-L{start},+{count}', '--porcelain', '--', file],
        capture_output=True, text=True)
    if result.returncode != 0:
        continue
    for bline in result.stdout.splitlines():
        if bline.startswith('author-mail '):
            email = bline[12:].strip('<> ')
            if email and not email.endswith('@users.noreply.github.com'):
                email_counts[email] += 1

if email_counts:
    print(email_counts.most_common(1)[0][0])
